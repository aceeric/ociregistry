#!/usr/bin/env bash
#
# Runs the registry from quay as a Docker container.
#
set -e

if [[ "$#" -ne 2 ]] && [[ "$#" -ne 3 ]]; then
  echo "usage: test-local-image <tag> <port> <optional path>"
  echo "e.g.: test-local-image 1.12.6 8080"
  echo "or:"
  echo "e.g.: test-local-image 1.12.6 8080 /tmp/images"
  exit 1
fi

if [[ -z "$3" ]]; then
  image_dir=$(mktemp -d)
else 
  image_dir=$3
fi
docker run\
  --detach\
  --name    ociregistry\
  --publish $2:8080\
  --user    $(id -u):$(id -g)\
  --volume  $image_dir:/var/lib/ociregistry\
  --entrypoint=/ociregistry/server\
  quay.io/appzygy/ociregistry:$1 --log-level info serve

echo "tail the logs: docker logs ociregistry -f"
echo "when done: docker stop ociregistry && docker container rm ociregistry && rm -rf $image_dir"
